generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id       String   @id @default(uuid())
  nome     String
  cpf      String   @unique
  email    String   @unique
  telefone String?
  criadoEm DateTime @default(now())
  contas   Conta[]
}

model Conta {
  id                  String      @id @default(uuid())
  numero              String      @unique @default(cuid())
  saldo               Float       @default(0)
  limite              Float       @default(0)
  ativa               Boolean     @default(true)
  criadoEm            DateTime    @default(now())
  clienteId           String
  cliente             Cliente     @relation(fields: [clienteId], references: [id])
  transacoesRecebidas Transacao[] @relation("ContaDestino")
  transacoesEnviadas  Transacao[] @relation("ContaOrigem")
}

model Transacao {
  id             String        @id @default(uuid())
  tipo           TipoTransacao
  valor          Float
  descricao      String?
  criadoEm       DateTime      @default(now())
  contaOrigemId  String?
  contaDestinoId String?
  contaDestino   Conta?        @relation("ContaDestino", fields: [contaDestinoId], references: [id])
  contaOrigem    Conta?        @relation("ContaOrigem", fields: [contaOrigemId], references: [id])
}

enum TipoTransacao {
  DEPOSITO
  SAQUE
  TRANSFERENCIA
}
